# Supabase Configuration
NUXT_PUBLIC_SUPABASE_URL=your_supabase_url
NUXT_PUBLIC_SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_url

# Database Configuration
DATABASE_URL=postgresql://postgres:[password]@db.your_project.supabase.co:5432/postgres

# Gmail Configuration (for email sending)
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password
EMAIL_JOBS_TOKEN=your_email_jobs_token

# Nuxt Secret Key
NUXT_SECRET_KEY=your_secret_key

# Base URL
NUXT_PUBLIC_BASE_URL=http://localhost:3000

# Cron Jobs
CRON_SECRET=gere_com_openssl_rand_hex_32

# Environment
ENVIRONMENT=Development

# Project Info
SUPABASE_PROJECT_ID=your_project_id
SUPABASE_PROJECT_NAME=your_project_name